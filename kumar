<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sri Venkateswara Public School – Cumbum</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Libre+Baskerville:ital,wght@0,400;0,700;1,400&family=Crimson+Pro:wght@300;400;600&display=swap" rel="stylesheet">
<style>
  :root {
    --saffron: #E8831A;
    --deep-saffron: #C4620A;
    --gold: #D4AF37;
    --light-gold: #F5E6A8;
    --cream: #FDF6E9;
    --dark-maroon: #4A1010;
    --maroon: #7B1D1D;
    --green: #1A5C2A;
    --text-dark: #2A1A0A;
    --text-mid: #5C3A1E;
    --white: #FFFDF5;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    font-family: 'Crimson Pro', serif;
    background: var(--cream);
    color: var(--text-dark);
    overflow-x: hidden;
  }

  /* ─── NAV ─── */
  nav {
    position: fixed; top: 0; width: 100%; z-index: 100;
    background: var(--dark-maroon);
    padding: 0 2rem;
    display: flex; align-items: center; justify-content: space-between;
    height: 56px;
    box-shadow: 0 2px 16px rgba(0,0,0,0.35);
  }
  .nav-logo {
    font-family: 'Playfair Display', serif;
    color: var(--light-gold);
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: 0.04em;
  }
  .nav-links { display: flex; gap: 1.8rem; list-style: none; }
  .nav-links a {
    color: #D9C08A;
    text-decoration: none;
    font-family: 'Crimson Pro', serif;
    font-size: 1rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: color .25s;
  }
  .nav-links a:hover { color: var(--light-gold); }

  /* ─── HERO ─── */
  .hero {
    min-height: 100vh;
    background:
      radial-gradient(ellipse at 70% 40%, rgba(212,175,55,0.18) 0%, transparent 60%),
      radial-gradient(ellipse at 20% 80%, rgba(232,131,26,0.12) 0%, transparent 55%),
      linear-gradient(160deg, #3D0B0B 0%, #4A1010 40%, #1A2A1A 100%);
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    text-align: center;
    padding: 6rem 2rem 4rem;
    position: relative;
    overflow: hidden;
  }

  /* decorative border pattern */
  .hero::before {
    content: '';
    position: absolute; inset: 18px;
    border: 1.5px solid rgba(212,175,55,0.3);
    pointer-events: none;
  }
  .hero::after {
    content: '';
    position: absolute; inset: 24px;
    border: .5px solid rgba(212,175,55,0.15);
    pointer-events: none;
  }

  .hero-emblem {
    font-size: 4.5rem;
    margin-bottom: 1.2rem;
    animation: floatEmb 4s ease-in-out infinite;
    filter: drop-shadow(0 0 18px rgba(212,175,55,0.5));
  }
  @keyframes floatEmb {
    0%,100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  .hero-est {
    font-family: 'Crimson Pro', serif;
    color: var(--gold);
    font-size: 0.85rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin-bottom: 1rem;
    opacity: 0;
    animation: fadeUp .8s .2s forwards;
  }

  .hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.2rem, 6vw, 4.2rem);
    font-weight: 900;
    color: var(--white);
    line-height: 1.15;
    opacity: 0;
    animation: fadeUp .9s .4s forwards;
    text-shadow: 0 2px 24px rgba(0,0,0,0.5);
    max-width: 800px;
  }

  .hero h1 span {
    color: var(--gold);
    font-style: italic;
  }

  .hero-tagline {
    margin-top: 1.4rem;
    color: #C9B07A;
    font-size: 1.2rem;
    font-style: italic;
    opacity: 0;
    animation: fadeUp .9s .7s forwards;
  }

  .hero-stats {
    margin-top: 3rem;
    display: flex; gap: 3rem; flex-wrap: wrap; justify-content: center;
    opacity: 0;
    animation: fadeUp .9s 1s forwards;
  }
  .stat-item { text-align: center; }
  .stat-num {
    font-family: 'Playfair Display', serif;
    font-size: 2.6rem; font-weight: 900;
    color: var(--gold);
    line-height: 1;
  }
  .stat-label {
    font-size: 0.8rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #A08850;
    margin-top: .3rem;
  }

  .hero-divider {
    width: 120px; height: 2px;
    background: linear-gradient(90deg, transparent, var(--gold), transparent);
    margin: 2.5rem auto 0;
    opacity: 0;
    animation: fadeUp .9s 1.2s forwards;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(24px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* ─── SECTIONS ─── */
  section { padding: 5rem 2rem; }
  .section-inner { max-width: 1100px; margin: 0 auto; }

  .section-label {
    font-family: 'Crimson Pro', serif;
    font-size: .78rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--saffron);
    margin-bottom: 0.6rem;
    display: block;
  }
  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    font-weight: 700;
    color: var(--dark-maroon);
    line-height: 1.2;
    margin-bottom: 0.5rem;
  }
  .title-rule {
    width: 60px; height: 3px;
    background: linear-gradient(90deg, var(--saffron), var(--gold));
    margin: 1rem 0 2.5rem;
    border-radius: 2px;
  }

  /* ─── ABOUT ─── */
  .about-section {
    background: var(--white);
    position: relative;
  }
  .about-section::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 5px;
    background: linear-gradient(90deg, var(--dark-maroon), var(--saffron), var(--gold), var(--green), var(--dark-maroon));
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .about-text p {
    font-size: 1.12rem;
    line-height: 1.85;
    color: var(--text-mid);
    margin-bottom: 1.2rem;
  }
  .about-text p strong {
    color: var(--dark-maroon);
    font-weight: 600;
  }

  .about-card-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.2rem;
  }
  .about-card {
    background: var(--cream);
    border: 1px solid rgba(212,175,55,0.3);
    border-radius: 4px;
    padding: 1.4rem;
    text-align: center;
    position: relative;
    overflow: hidden;
    transition: transform .3s, box-shadow .3s;
  }
  .about-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(74,16,16,0.12); }
  .about-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, var(--saffron), var(--gold));
  }
  .about-card-icon { font-size: 2rem; margin-bottom: .5rem; }
  .about-card-val {
    font-family: 'Playfair Display', serif;
    font-size: 1.9rem;
    font-weight: 700;
    color: var(--dark-maroon);
  }
  .about-card-desc {
    font-size: 0.82rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-mid);
    margin-top: .3rem;
  }

  /* ─── GRADES ─── */
  .grades-section {
    background: linear-gradient(135deg, #4A1010 0%, #3D0B0B 100%);
    position: relative;
    overflow: hidden;
  }
  .grades-section::before {
    content: '॰ ॰ ॰ ॰ ॰ ॰ ॰ ॰ ॰ ॰';
    position: absolute; top: 0; left: 0; right: 0;
    text-align: center; color: rgba(212,175,55,0.15);
    font-size: 2rem; padding: .5rem 0;
    letter-spacing: .5rem;
  }
  .grades-section .section-title { color: var(--light-gold); }
  .grades-section .section-label { color: var(--gold); opacity: 0.8; }

  .grades-list {
    display: flex; flex-wrap: wrap; gap: 1rem;
    justify-content: center; margin-top: 2rem;
  }
  .grade-pill {
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(212,175,55,0.35);
    color: var(--light-gold);
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    padding: .7rem 1.8rem;
    border-radius: 2px;
    letter-spacing: 0.05em;
    transition: background .25s, border-color .25s;
    cursor: default;
  }
  .grade-pill:hover {
    background: rgba(212,175,55,0.15);
    border-color: var(--gold);
  }
  .grade-pill.highlight {
    background: linear-gradient(135deg, var(--saffron), var(--gold));
    border-color: transparent;
    color: #fff;
    font-weight: 700;
  }

  /* ─── STAFF ─── */
  .staff-section { background: var(--cream); }

  .staff-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    gap: 1.8rem;
    margin-top: 1rem;
  }

  .staff-card {
    background: var(--white);
    border: 1px solid rgba(200,180,140,0.4);
    border-radius: 4px;
    padding: 2rem 1.5rem 1.5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
    transition: transform .3s, box-shadow .3s;
  }
  .staff-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 32px rgba(74,16,16,0.14);
  }
  .staff-card.founder {
    grid-column: span 2;
    background: linear-gradient(160deg, #FDF6E9, #FFF8E8);
    border-color: var(--gold);
  }
  .staff-card.founder::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 4px;
    background: linear-gradient(90deg, var(--dark-maroon), var(--saffron), var(--gold), var(--saffron), var(--dark-maroon));
  }
  .staff-card::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 3px;
    background: linear-gradient(90deg, var(--saffron), var(--gold));
  }
  .staff-card.founder::before { height: 4px; }

  .staff-avatar {
    width: 80px; height: 80px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--saffron), var(--gold));
    display: flex; align-items: center; justify-content: center;
    font-size: 2rem;
    margin: 0 auto 1.2rem;
    border: 3px solid var(--light-gold);
    box-shadow: 0 4px 12px rgba(212,175,55,0.3);
  }
  .staff-card.founder .staff-avatar {
    width: 96px; height: 96px;
    font-size: 2.5rem;
    background: linear-gradient(135deg, var(--dark-maroon), var(--maroon));
    border-color: var(--gold);
    box-shadow: 0 6px 20px rgba(212,175,55,0.4);
  }
  .staff-badge {
    position: absolute; top: 1rem; right: 1rem;
    background: var(--gold);
    color: var(--dark-maroon);
    font-size: .65rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: .25rem .6rem;
    border-radius: 2px;
  }
  .staff-name {
    font-family: 'Playfair Display', serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--dark-maroon);
    margin-bottom: .25rem;
  }
  .staff-card.founder .staff-name { font-size: 1.35rem; }
  .staff-role {
    font-size: .78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--saffron);
    font-weight: 600;
    margin-bottom: .8rem;
  }
  .staff-subject {
    display: inline-block;
    background: rgba(232,131,26,0.1);
    color: var(--saffron);
    font-size: .78rem;
    padding: .2rem .7rem;
    border-radius: 2px;
    margin-bottom: .8rem;
    border: 1px solid rgba(232,131,26,0.25);
  }
  .staff-meta {
    font-size: .88rem;
    color: var(--text-mid);
    line-height: 1.6;
  }
  .staff-meta span {
    display: inline-block;
    background: var(--cream);
    padding: .15rem .5rem;
    border-radius: 2px;
    margin: .15rem;
    font-size: .8rem;
  }

  /* ─── CONTACT ─── */
  .contact-section {
    background: linear-gradient(160deg, #4A1010 0%, #2A1A0A 100%);
  }
  .contact-section .section-title { color: var(--light-gold); }
  .contact-section .section-label { color: var(--gold); opacity: .8; }
  .contact-section .title-rule { background: linear-gradient(90deg, var(--gold), var(--saffron)); }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  .contact-item {
    display: flex; align-items: flex-start; gap: 1.2rem;
    margin-bottom: 2rem;
  }
  .contact-icon {
    width: 48px; height: 48px; min-width: 48px;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(212,175,55,0.3);
    border-radius: 3px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.3rem;
  }
  .contact-info-label {
    font-size: .72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: .3rem;
  }
  .contact-info-val {
    color: #D9C08A;
    font-size: 1rem;
    line-height: 1.6;
  }
  .contact-info-val a { color: var(--light-gold); text-decoration: none; }
  .contact-info-val a:hover { color: var(--gold); text-decoration: underline; }

  .contact-cta {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(212,175,55,0.25);
    border-radius: 4px;
    padding: 2.5rem;
    text-align: center;
  }
  .contact-cta h3 {
    font-family: 'Playfair Display', serif;
    color: var(--light-gold);
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }
  .contact-cta p {
    color: #A08850;
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 1.8rem;
  }
  .cta-btn {
    display: inline-block;
    background: linear-gradient(135deg, var(--saffron), var(--gold));
    color: #fff;
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    padding: .9rem 2.4rem;
    border-radius: 2px;
    text-decoration: none;
    transition: opacity .25s, transform .25s;
    box-shadow: 0 4px 16px rgba(232,131,26,0.35);
  }
  .cta-btn:hover { opacity: .9; transform: translateY(-2px); }

  /* ─── FOOTER ─── */
  footer {
    background: #1A0A0A;
    padding: 2rem;
    text-align: center;
    color: #6A4A2A;
    font-size: .88rem;
    letter-spacing: 0.06em;
  }
  footer span { color: var(--saffron); }

  /* ─── MOBILE ─── */
  @media (max-width: 720px) {
    .about-grid { grid-template-columns: 1fr; gap: 2.5rem; }
    .contact-grid { grid-template-columns: 1fr; }
    .staff-card.founder { grid-column: span 1; }
    .nav-links { display: none; }
    .hero-stats { gap: 2rem; }
    .about-card-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
</head>
